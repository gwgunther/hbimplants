---
import '../styles/global.css';
import { site, address } from '../config/site';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" type="image/png" href="/images/branding/logo-black.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700&display=swap"
      />
    </noscript>

    <!-- GA4 -->
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){window.dataLayer.push(arguments);}
          window.gtag('js', new Date());
          window.gtag('config', ga4Id);
        </script>
      </>
    )}
  </head>
  <body class="bg-white">

    <!-- Sticky nav bar -->
    <header class="sticky top-0 z-50 bg-white border-b border-neutral-border shadow-sm">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" aria-label="Huntington Beach Prosthodontics homepage">
          <img
            src="/images/branding/logo-black.png"
            alt="Huntington Beach Prosthodontics"
            class="h-8 w-auto"
            width="180"
            height="32"
          />
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="flex items-center gap-2 text-brand-navy font-bold text-base sm:text-lg hover:text-brand-blue transition-colors"
        >
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-brand-gold flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          {site.phone}
        </a>
      </div>
    </header>

    <!-- Trust bar -->
    <div class="bg-brand-navy text-white text-xs sm:text-sm py-2">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-wrap justify-center gap-x-5 gap-y-1 text-center">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          4.9 Google Rating
        </span>
        <span>Board-Certified Prosthodontist</span>
        <span>Huntington Beach, CA</span>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-surface-2 border-t border-neutral-border py-8 pb-24 sm:pb-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center text-sm text-neutral-mid">
        <p class="mb-1 font-medium text-charcoal">{site.name}</p>
        <p class="mb-1">{address.full}</p>
        <p class="mb-4">
          <a href={`tel:${site.phoneDigits}`} class="text-brand-blue hover:underline">{site.phone}</a>
        </p>
        <p class="text-xs text-neutral-mid">
          &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
          &nbsp;&middot;&nbsp;
          <a href="/" class="hover:underline">Full Website</a>
        </p>
      </div>
    </footer>

    <!-- Mobile sticky CTA bar -->
    <div class="fixed bottom-0 left-0 right-0 z-50 sm:hidden bg-white border-t border-neutral-border shadow-lg px-4 py-3 flex gap-3">
      <a
        href={`tel:${site.phoneDigits}`}
        class="flex-1 bg-brand-gold text-white text-center font-semibold py-3 rounded-full text-sm"
      >
        Call Now
      </a>
      <a
        href={site.bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-track="booking"
        class="flex-1 bg-brand-navy text-white text-center font-semibold py-3 rounded-full text-sm"
      >
        Book Online
      </a>
    </div>

    <!-- Conversion tracking -->
    <script>
      document.addEventListener('click', (e) => {
        const tel = (e.target as Element).closest('a[href^="tel:"]');
        if (tel && typeof window.gtag === 'function') {
          window.gtag('event', 'phone_click', { event_category: 'contact' });
        }
        const booking = (e.target as Element).closest('[data-track="booking"]');
        if (booking && typeof window.gtag === 'function') {
          window.gtag('event', 'booking_click', { event_category: 'conversion' });
        }
      });
    </script>
  </body>
</html>
