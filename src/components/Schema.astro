---
interface Props {
  type: 'LocalBusiness' | 'MedicalProcedure' | 'FAQPage';
  procedure?: {
    name: string;
    description: string;
  };
  faqs?: Array<{
    question: string;
    answer: string;
  }>;
}

const { type, procedure, faqs } = Astro.props;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '[PHONE]',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '[STREET]',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '[ZIP]',
    'addressCountry': 'US',
  },
  'openingHours': ['[HOURS]'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
  'sameAs': [
    '[GOOGLE_REVIEW_LINK]',
  ],
};

const medicalProcedure = procedure ? {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  'name': procedure.name,
  'description': procedure.description,
  'procedureType': 'https://schema.org/TherapeuticProcedure',
  'bodyLocation': 'Mouth',
  'followup': 'As recommended by your prosthodontist',
} : null;

const faqPage = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map((faq) => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
} : null;

const schemas = [
  localBusiness,
  type === 'MedicalProcedure' ? medicalProcedure : null,
  type === 'FAQPage' ? faqPage : null,
].filter(Boolean);
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
