---
interface Props {
  heading?: string;
  subheading?: string;
  primaryCTA?: string;
  primaryHref?: string;
  phone?: string;
  variant?: 'navy' | 'light' | 'white';
}

const {
  heading = 'Ready to Restore Your Smile?',
  subheading = 'Schedule a consultation with Dr. Favian Cheong, your board-certified prosthodontist in Huntington Beach. We\'ll create a personalized treatment plan just for you.',
  primaryCTA = 'Schedule Your Consultation',
  primaryHref = '/schedule',
  phone = '(714) 846-1386',
  variant = 'navy',
} = Astro.props;

const bgClass = {
  navy: 'bg-brand-navy text-white',
  light: 'bg-brand-light text-brand-navy',
  white: 'bg-white text-brand-navy border border-neutral-border',
}[variant];

const headingClass = {
  navy: 'text-white',
  light: 'text-brand-navy',
  white: 'text-brand-navy',
}[variant];

const subClass = {
  navy: 'text-gray-300',
  light: 'text-neutral-mid',
  white: 'text-neutral-mid',
}[variant];
---

<section class={`${bgClass} rounded-2xl p-8 md:p-12 text-center`}>
  <h2 class={`font-serif text-2xl md:text-3xl font-bold mb-4 ${headingClass}`}>
    {heading}
  </h2>
  <p class={`max-w-2xl mx-auto mb-8 leading-relaxed ${subClass}`}>
    {subheading}
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <a href={primaryHref} class="btn-gold text-base px-8 py-4 font-semibold">
      {primaryCTA}
    </a>
    <a
      href={`tel:${phone.replace(/\D/g, '')}`}
      class={`font-semibold text-base transition-colors ${variant === 'navy' ? 'text-brand-gold hover:text-white' : 'text-brand-blue hover:text-brand-navy'}`}
    >
      Or Call: {phone}
    </a>
  </div>
</section>
