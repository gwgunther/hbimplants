---
interface GalleryItem {
  before: string;
  after: string;
  beforeAlt: string;
  afterAlt: string;
  caption?: string;
  procedure?: string;
}

interface Props {
  items: GalleryItem[];
  heading?: string;
}

const {
  items,
  heading = 'Before & After Results',
} = Astro.props;
---

<section class="py-12">
  <h2 class="section-subheading text-center mb-2">{heading}</h2>
  <p class="text-center text-neutral-mid mb-8 text-sm">Individual results may vary. Photos shown with patient consent.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item, index) => (
      <div
        class="card cursor-pointer group"
        data-lightbox-index={index}
        role="button"
        tabindex="0"
        aria-label={`View before and after: ${item.caption || item.procedure || 'Treatment result'}`}
      >
        {item.procedure && (
          <div class="text-xs font-semibold text-brand-blue uppercase tracking-wide mb-3">
            {item.procedure}
          </div>
        )}
        <div class="grid grid-cols-2 gap-2 mb-3">
          <div>
            <div class="text-xs text-neutral-mid font-medium mb-1 text-center">BEFORE</div>
            <div class="aspect-square bg-neutral-light rounded-lg overflow-hidden">
              <img
                src={item.before}
                alt={item.beforeAlt}
                width="200"
                height="200"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          </div>
          <div>
            <div class="text-xs text-neutral-mid font-medium mb-1 text-center">AFTER</div>
            <div class="aspect-square bg-neutral-light rounded-lg overflow-hidden">
              <img
                src={item.after}
                alt={item.afterAlt}
                width="200"
                height="200"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          </div>
        </div>
        {item.caption && (
          <p class="text-sm text-neutral-mid text-center">{item.caption}</p>
        )}
      </div>
    ))}
  </div>
</section>
