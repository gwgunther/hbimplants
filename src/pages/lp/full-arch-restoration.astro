---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { site, doctor } from '../../config/site';

const faqs = [
  {
    q: 'What is full arch restoration?',
    a: 'Full arch restoration replaces every tooth in an upper or lower arch with implant-supported teeth. Unlike dentures, they are fixed in place — you cannot remove them. They function, feel, and look like natural teeth.',
  },
  {
    q: 'How is this different from dentures?',
    a: 'Dentures rest on your gums and can slip, click, or fall out. Full arch implants are anchored to your jawbone — permanently. No adhesive, no nightly removal, no slippage. They also preserve your jawbone, which dentures do not.',
  },
  {
    q: 'Will I have to go without teeth during the process?',
    a: 'No. In most cases, you receive temporary teeth on the day of your implant procedure. You will not go without a smile at any stage of treatment.',
  },
  {
    q: 'What if I\'ve already experienced bone loss from wearing dentures?',
    a: 'Bone loss is common after years of denture wear, but it does not necessarily disqualify you. Bone grafting can often restore enough volume for implants. Dr. Cheong will evaluate your current bone level at your consultation and outline your options clearly.',
  },
];
---

<LandingLayout
  title="Full Arch Dental Implants Huntington Beach | Done With Dentures"
  description="Permanent full arch implants in Huntington Beach. Replace dentures with fixed, implant-supported teeth. Dr. Favian Cheong, board-certified prosthodontist. Free consultation."
>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-16 md:py-24" style="background-image: linear-gradient(135deg, #1B3828 60%, #2D6645 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-brand-gold font-semibold text-sm uppercase tracking-widest mb-4">Permanent Implant-Supported Teeth · Huntington Beach, CA</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        Done With Dentures?<br class="hidden md:block" /> There's a Permanent Fix.
      </h1>
      <p class="text-white/85 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Full arch implants replace everything — permanently. No slipping. No removal. No adhesive. Just teeth that feel like yours, planned and placed by {doctor.name}, {doctor.credentials}.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-brand-gold text-white font-bold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-opacity text-center"
        >
          Book Free Consultation
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="bg-white/10 border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/20 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
      <p class="text-white/60 text-sm mt-5">No obligation · Financing available · Most insurance accepted</p>
    </div>
  </section>

  <!-- Dentures vs Implants comparison -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-4 text-center">
        Dentures vs. Full Arch Implants
      </h2>
      <p class="text-neutral-mid text-center max-w-2xl mx-auto mb-12">
        See the difference at a glance.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Dentures column -->
        <div class="border border-neutral-border rounded-xl overflow-hidden">
          <div class="bg-neutral-light px-6 py-4 font-semibold text-neutral-mid text-center border-b border-neutral-border">Traditional Dentures</div>
          <ul class="divide-y divide-neutral-border">
            {[
              'Rests on gums — can slip or click',
              'Must be removed nightly',
              'Requires adhesive for stability',
              'Bone loss continues underneath',
              'Limits what you can eat',
              'Needs replacement every 5–7 years',
            ].map((item) => (
              <li class="flex items-center gap-3 px-6 py-3 text-sm text-neutral-mid">
                <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Implants column -->
        <div class="border-2 border-brand-navy rounded-xl overflow-hidden">
          <div class="bg-brand-navy px-6 py-4 font-semibold text-white text-center">Full Arch Implants</div>
          <ul class="divide-y divide-neutral-border">
            {[
              'Fixed to jawbone — never moves',
              'Permanent — stays in 24/7',
              'No adhesive needed, ever',
              'Stimulates bone — prevents further loss',
              'Eat anything, including hard foods',
              'Designed to last a lifetime',
            ].map((item) => (
              <li class="flex items-center gap-3 px-6 py-3 text-sm text-charcoal">
                <svg class="w-4 h-4 text-brand-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why prosthodontist -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="md:flex items-center gap-12">
        <div class="flex-1">
          <p class="text-brand-gold font-semibold text-sm uppercase tracking-widest mb-3">Why Choose Dr. Cheong</p>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-5">
            A Prosthodontist Plans the Whole Picture
          </h2>
          <p class="text-neutral-mid mb-5 leading-relaxed">
            Full arch restoration is one of the most complex procedures in dentistry. It requires precision at every step — bone evaluation, implant positioning, arch design, bite alignment, and aesthetic planning.
          </p>
          <p class="text-neutral-mid mb-5 leading-relaxed">
            {doctor.name} is board-certified in prosthodontics — a specialty that requires 3 additional years of advanced training focused entirely on this type of full-mouth restoration. He designs the final arch first, then works backwards to ensure everything is built around it.
          </p>
          <p class="text-neutral-mid leading-relaxed">
            The result is a predictable, coordinated outcome — not a patchwork of decisions made as you go.
          </p>
        </div>
        <div class="flex-shrink-0 mt-8 md:mt-0">
          <div class="bg-white rounded-2xl p-8 border border-neutral-border text-center max-w-xs">
            <div class="font-serif text-5xl font-bold text-brand-navy mb-1">4.9</div>
            <div class="flex justify-center gap-1 mb-2" aria-label="4.9 out of 5 stars">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-sm text-neutral-mid">200+ Google Reviews</p>
            <div class="border-t border-neutral-border mt-4 pt-4">
              <p class="text-xs text-neutral-mid font-medium uppercase tracking-widest">Board-Certified</p>
              <p class="text-sm font-semibold text-charcoal">Prosthodontist</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid CTA -->
  <section class="py-12 bg-brand-gold">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-white font-serif text-2xl font-bold mb-2">Ready to leave dentures behind?</p>
      <p class="text-white/85 mb-6">Free full arch evaluation with {doctor.name}. No commitment required.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-white text-brand-navy font-bold px-8 py-4 rounded-full hover:opacity-90 transition-opacity text-center"
        >
          Book Free Consultation
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="border border-white text-white font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-10 text-center">
        Your Questions Answered
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group border border-neutral-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-charcoal list-none hover:bg-surface-2 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-brand-navy flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-1 text-neutral-mid text-sm leading-relaxed border-t border-neutral-border">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-brand-navy text-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">
        Your First Step: A Free Consultation
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        {doctor.name} will review your imaging, assess your bone structure, and tell you exactly what full arch restoration would look like for you — including cost and timeline.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-brand-gold text-white font-bold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-opacity text-center"
        >
          Book Online Now
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="bg-white/10 border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/20 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
      <p class="text-white/50 text-sm">Most insurance accepted &middot; CareCredit &amp; financing available &middot; Huntington Beach, CA</p>
    </div>
  </section>

</LandingLayout>
