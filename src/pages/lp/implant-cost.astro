---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { site, doctor } from '../../config/site';

const faqs = [
  {
    q: 'Why do implant prices vary so much online?',
    a: 'Online price ranges (often $1,000–$6,000 per implant) rarely reflect the full picture. A complete single-tooth implant includes the implant post, abutment, and custom crown — each a separate cost. Full arch options like All-on-4 involve surgery, materials, and lab fees. We give you a complete, itemized estimate at your free consultation.',
  },
  {
    q: 'Does dental insurance cover implants?',
    a: 'Many plans offer partial coverage for implant components — often covering the crown or a portion of the surgical fee. Our team will verify your specific benefits before your appointment so there are no surprises.',
  },
  {
    q: 'What financing options are available?',
    a: 'We work with CareCredit and other financing partners. Many patients qualify for 0% promotional financing, spreading the cost into manageable monthly payments. We will walk you through options at your consultation.',
  },
  {
    q: 'Is a cheaper implant from a different provider worth the savings?',
    a: 'Implants are a permanent investment in your jaw and your smile. Cutting costs on a component that integrates with your bone carries real risks — including implant failure, complications requiring correction, and poor aesthetics. With Dr. Cheong, you get specialist-level expertise and quality materials from the start.',
  },
];
---

<LandingLayout
  title="Dental Implant Cost Huntington Beach | Transparent Pricing"
  description="Wondering how much dental implants cost in Huntington Beach? Get transparent pricing and a free personalized quote from Dr. Favian Cheong, DDS, MS. Financing available."
>

  <!-- Hero -->
  <section class="bg-brand-navy text-white py-16 md:py-24" style="background-image: linear-gradient(135deg, #1B3828 60%, #2D6645 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-brand-gold font-semibold text-sm uppercase tracking-widest mb-4">Transparent Pricing · No Hidden Fees · Huntington Beach</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        What Do Dental Implants<br class="hidden md:block" /> Cost in Huntington Beach?
      </h1>
      <p class="text-white/85 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Every case is different — but you deserve a clear, honest estimate before committing to anything. {doctor.name}, {doctor.credentials} provides transparent, itemized pricing at a free consultation. No surprises.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-brand-gold text-white font-bold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-opacity text-center"
        >
          Get My Free Cost Estimate
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="bg-white/10 border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/20 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
      <p class="text-white/60 text-sm mt-5">Free consultation · Most insurance accepted · Financing available</p>
    </div>
  </section>

  <!-- What's actually included in the cost -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-4 text-center">
        What's Actually Included in Implant Cost
      </h2>
      <p class="text-neutral-mid text-center max-w-2xl mx-auto mb-12">
        Online ads show a single number — but implant pricing has several components. Here's what a complete, honest estimate covers.
      </p>
      <div class="space-y-4">
        {[
          {
            label: 'Consultation & Imaging',
            note: 'Free with us',
            body: 'Includes clinical exam, digital X-rays, and in some cases a 3D CBCT scan to evaluate your bone and plan placement precisely.',
          },
          {
            label: 'Implant Post (Titanium Root)',
            note: 'The surgical component',
            body: 'The titanium fixture that is surgically placed into your jawbone. Quality varies significantly by brand — we use trusted, proven systems.',
          },
          {
            label: 'Abutment',
            note: 'The connector',
            body: 'Connects the implant post to the crown. Custom abutments (vs. stock) result in a better-fitting, more natural-looking restoration.',
          },
          {
            label: 'Crown (The Visible Tooth)',
            note: 'The final restoration',
            body: 'The custom ceramic or porcelain crown that looks and functions like a natural tooth. As a prosthodontist, Dr. Cheong designs this to match your existing teeth precisely.',
          },
          {
            label: 'Bone Graft (If Needed)',
            note: 'Not always required',
            body: 'If there has been bone loss, a graft may be needed before implant placement. This is evaluated at your consultation and factored into your estimate.',
          },
        ].map((item) => (
          <div class="bg-surface-2 rounded-xl p-5 border border-neutral-border flex flex-col sm:flex-row sm:items-start gap-3">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1">
                <span class="font-semibold text-charcoal">{item.label}</span>
                <span class="text-xs bg-brand-light text-brand-navy px-2 py-0.5 rounded-full font-medium">{item.note}</span>
              </div>
              <p class="text-sm text-neutral-mid">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-neutral-mid mt-8">
        Every item is included in your written estimate. No bill surprises after treatment begins.
      </p>
    </div>
  </section>

  <!-- Financing section -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-4 text-center">
        Financing That Makes It Accessible
      </h2>
      <p class="text-neutral-mid text-center max-w-2xl mx-auto mb-12">
        Most patients don't pay out of pocket all at once. Here's how to make implants fit your budget.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card text-center">
          <div class="w-12 h-12 bg-brand-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-charcoal mb-2">CareCredit Financing</h3>
          <p class="text-sm text-neutral-mid">0% promotional financing plans available. Spread your treatment cost into manageable monthly payments with no interest during the promotional period.</p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 bg-brand-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-charcoal mb-2">Insurance Maximization</h3>
          <p class="text-sm text-neutral-mid">Our team verifies your dental benefits before your appointment and identifies every applicable coverage — so you keep more money in your pocket.</p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 bg-brand-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-charcoal mb-2">Phased Treatment</h3>
          <p class="text-sm text-neutral-mid">When appropriate, treatment can be staged across multiple benefit years, allowing you to apply your insurance maximum each year and reduce out-of-pocket cost.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid CTA -->
  <section class="py-12 bg-brand-gold">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-white font-serif text-2xl font-bold mb-2">Get your personalized cost estimate — free.</p>
      <p class="text-white/85 mb-6">No vague ranges. A real number based on your actual case.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-white text-brand-navy font-bold px-8 py-4 rounded-full hover:opacity-90 transition-opacity text-center"
        >
          Book Free Consultation
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="border border-white text-white font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Why quality matters -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-4 text-center">
        Why the "Cheapest" Option Often Costs More
      </h2>
      <p class="text-neutral-mid text-center max-w-2xl mx-auto mb-12">
        Implants integrate permanently with your jawbone. The quality of the planning and components matters — for decades.
      </p>
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div class="space-y-5">
          {[
            { title: 'Specialist Training', body: 'Dr. Cheong completed 3 additional years of prosthodontic specialty training focused on tooth replacement. Most implant providers are general dentists without this specialty background.' },
            { title: 'Precision Planning', body: 'Every implant case is treatment-planned from the final restoration backwards. This means the implant goes exactly where it needs to for the best possible crown outcome.' },
            { title: 'Quality Materials', body: 'We use established implant systems with long-term clinical data. Discount implants from unfamiliar brands carry higher failure and complication rates.' },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="w-2 flex-shrink-0 bg-brand-gold rounded-full mt-2 self-start" style="height: 1.25rem;"></div>
              <div>
                <h3 class="font-semibold text-charcoal mb-1">{item.title}</h3>
                <p class="text-sm text-neutral-mid">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="bg-surface-2 rounded-2xl p-8 border border-neutral-border text-center">
          <p class="font-serif text-xl font-bold text-charcoal mb-3">Think of it as a long-term investment.</p>
          <p class="text-neutral-mid text-sm leading-relaxed mb-5">
            A well-placed implant with a quality crown, done by a specialist, can last 25–30+ years. A failed implant — from poor planning or inferior components — can cost more to correct than the original procedure.
          </p>
          <a
            href={site.bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="booking"
            class="btn-primary text-sm px-6 py-3"
          >
            Get a Specialist's Quote — Free
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mb-10 text-center">
        Cost Questions Answered
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group border border-neutral-border rounded-xl overflow-hidden bg-white">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-charcoal list-none hover:bg-surface-2 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-brand-navy flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-1 text-neutral-mid text-sm leading-relaxed border-t border-neutral-border">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-brand-navy text-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">
        Know Your Number Before You Decide
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        {doctor.name} will give you an itemized estimate based on your actual imaging and treatment needs — at no charge, with no pressure to commit.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="booking"
          class="bg-brand-gold text-white font-bold px-8 py-4 rounded-full text-lg hover:opacity-90 transition-opacity text-center"
        >
          Book Free Cost Consultation
        </a>
        <a
          href={`tel:${site.phoneDigits}`}
          class="bg-white/10 border border-white/30 text-white font-semibold px-8 py-4 rounded-full text-lg hover:bg-white/20 transition-colors text-center"
        >
          Call {site.phone}
        </a>
      </div>
      <p class="text-white/50 text-sm">Most insurance accepted &middot; CareCredit &amp; financing available &middot; Huntington Beach, CA</p>
    </div>
  </section>

</LandingLayout>
