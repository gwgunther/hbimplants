---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import FAQBlock from '../components/FAQBlock.astro';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};

const faqs = [
  {
    question: 'What is a prosthodontist and how is it different from a general dentist?',
    answer: 'A prosthodontist is a dental specialist who completes an additional 3 years of post-doctoral training beyond dental school, focusing exclusively on the restoration and replacement of teeth. While general dentists provide a broad range of dental care, prosthodontists are specialists in complex restorations, dental implants, veneers, dentures, and full-mouth rehabilitation. When your smile involves multiple missing teeth, implants, or complex cosmetic goals, a prosthodontist delivers a higher level of expertise and precision.',
  },
  {
    question: 'What procedures does Huntington Beach Prosthodontics offer?',
    answer: 'We offer the full spectrum of prosthodontic care including dental implants, All-on-4 and All-on-X full arch implants, porcelain veneers, smile makeovers, dentures, implant-supported dentures, snap-on dentures, implant crowns and bridges, cosmetic dentistry, restorative dentistry, and clear aligners. Every treatment plan is customized to your goals, anatomy, and budget.',
  },
  {
    question: 'How do I know if I\'m a candidate for dental implants?',
    answer: 'Most adults with one or more missing teeth are candidates for dental implants. The key factors are sufficient bone volume in the jaw, healthy gums, and no uncontrolled systemic conditions. During your complimentary consultation, we perform a thorough examination including 3D imaging to evaluate your bone density and determine the optimal implant plan. Even patients with bone loss may qualify after bone grafting.',
  },
  {
    question: 'Do you offer financing for dental implants and other procedures?',
    answer: 'Yes. We understand that prosthodontic procedures represent a significant investment. We offer flexible financing options and accept most major dental insurance plans. Our team will review your coverage and help you maximize benefits. We also work with third-party financing providers so you can start treatment today and pay over time.',
  },
  {
    question: 'How long does a dental implant last?',
    answer: 'Dental implants are designed to last a lifetime. The titanium implant post integrates with your jawbone through a process called osseointegration, creating a permanent anchor. The crown on top typically lasts 15–25 years with proper care. Regular check-ups, good oral hygiene, and avoiding habits like grinding are the keys to maximizing implant longevity.',
  },
  {
    question: 'Where is Huntington Beach Prosthodontics located?',
    answer: 'We are conveniently located in Huntington Beach, California, serving patients from Huntington Beach, Fountain Valley, Costa Mesa, Newport Beach, Seal Beach, and surrounding communities. Please call us or use our online appointment form to schedule your visit.',
  },
];
---

<BaseLayout
  title="Prosthodontist Huntington Beach | Dental Implants & Smile Restoration"
  description="Huntington Beach Prosthodontics offers dental implants, All-on-X, veneers, and full smile restorations. Board-certified prosthodontist serving HB, CA. Call today."
  schema={localBusiness}
>
  <!-- Hero -->
  <section class="relative bg-brand-navy text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-navy to-brand-blue opacity-95"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold px-4 py-2 rounded-full mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          Board-Certified Prosthodontist in Huntington Beach, CA
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Restore Your Smile.<br />
          <span class="text-brand-gold">Reclaim Your Confidence.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed max-w-2xl">
          Huntington Beach Prosthodontics specializes in dental implants, All-on-X full arch restorations, porcelain veneers, and complete smile makeovers — with precision that only a specialist delivers.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold text-center">
            Schedule Free Consultation
          </a>
          <a href="/dental-implants" class="btn-secondary text-base px-8 py-4 font-semibold text-center border-white text-white hover:bg-white hover:text-brand-navy">
            Explore Dental Implants
          </a>
        </div>
        <div class="flex items-center gap-6 mt-8 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            No referral needed
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Most insurance accepted
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Flexible financing
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="bg-brand-light py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="font-serif text-3xl font-bold text-brand-navy mb-1">3+ Yrs</div>
          <div class="text-sm text-neutral-mid">Specialty Training<br />Beyond Dental School</div>
        </div>
        <div>
          <div class="font-serif text-3xl font-bold text-brand-navy mb-1">1,000s</div>
          <div class="text-sm text-neutral-mid">Smiles Restored<br />in Huntington Beach</div>
        </div>
        <div>
          <div class="font-serif text-3xl font-bold text-brand-navy mb-1">5★</div>
          <div class="text-sm text-neutral-mid">Google Reviews<br />from Real Patients</div>
        </div>
        <div>
          <div class="font-serif text-3xl font-bold text-brand-navy mb-1">Same</div>
          <div class="text-sm text-neutral-mid">Day Consultations<br />Available</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">Specialized Prosthodontic Care</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          From single tooth implants to complete smile transformations, we offer the full spectrum of advanced dental restoration — performed by a specialist, not a generalist.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Dental Implants -->
        <a href="/dental-implants" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">Dental Implants</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">The gold standard for tooth replacement. Permanent, natural-looking, and built to last a lifetime.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>

        <!-- All-on-X -->
        <a href="/all-on-x" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">All-on-X / Full Arch</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Replace an entire arch of teeth with just 4–6 implants. Walk in with failing teeth, leave with a full smile.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>

        <!-- Veneers -->
        <a href="/veneers" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">Porcelain Veneers</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Transform the color, shape, and symmetry of your smile with ultra-thin porcelain shells crafted to perfection.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>

        <!-- Dentures -->
        <a href="/dentures" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">Dentures</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Modern full and partial dentures that look natural and fit comfortably — far beyond what your grandfather wore.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>

        <!-- Implant Restorations -->
        <a href="/implant-restorations" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">Implant Restorations</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Crowns, bridges, and dentures anchored to implants for maximum stability, function, and natural appearance.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>

        <!-- Cosmetic Dentistry -->
        <a href="/cosmetic-dentistry" class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">Cosmetic Dentistry</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Teeth whitening, bonding, and comprehensive smile makeovers designed around your unique facial features and goals.</p>
          <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose a Prosthodontist -->
  <section class="bg-brand-light py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-heading mb-6">Why Choose a Prosthodontist in Huntington Beach?</h2>
          <p class="text-neutral-mid leading-relaxed mb-6">
            When it comes to dental implants, veneers, or full-mouth reconstruction, the difference between a general dentist and a prosthodontist isn't subtle — it's fundamental. Prosthodontists complete 3 additional years of residency training dedicated entirely to complex tooth restoration and replacement.
          </p>
          <p class="text-neutral-mid leading-relaxed mb-6">
            At Huntington Beach Prosthodontics, Dr. Favian Cheong brings that specialized expertise to every case. Whether you need a single implant or a full-arch transformation, you're in the hands of someone who does nothing else, every day, at the highest level.
          </p>
          <ul class="space-y-3">
            {[
              'Board-certified prosthodontist with advanced specialty training',
              'Comprehensive treatment planning using the latest 3D imaging',
              'All restorations designed and coordinated in-house',
              'Experience with the most complex reconstructive cases',
              'Aesthetic excellence backed by clinical precision',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-neutral-mid">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/about" class="btn-primary">Meet Dr. Favian Cheong</a>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg border border-neutral-border">
          <h3 class="font-serif text-2xl font-bold text-brand-navy mb-6">Prosthodontist vs. General Dentist</h3>
          <div class="space-y-4">
            {[
              { area: 'Specialty Training', pros: '3+ additional years', gen: 'No specialty training' },
              { area: 'Dental Implants', pros: 'Advanced expertise', gen: 'Basic procedures only' },
              { area: 'Complex Cases', pros: 'Primary focus', gen: 'Refer out often' },
              { area: 'Full-Mouth Rehab', pros: 'Comprehensive planning', gen: 'Limited scope' },
              { area: 'Cosmetic Precision', pros: 'Specialized aesthetic training', gen: 'General aesthetics' },
            ].map((row) => (
              <div class="grid grid-cols-3 gap-2 text-sm">
                <div class="font-semibold text-brand-navy">{row.area}</div>
                <div class="text-green-700 font-medium flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {row.pros}
                </div>
                <div class="text-neutral-mid">{row.gen}</div>
              </div>
            ))}
          </div>
          <div class="mt-6 pt-6 border-t border-neutral-border text-center">
            <a href="/schedule" class="btn-primary w-full block">Schedule Free Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">What Our Patients Say</h2>
        <div class="flex items-center justify-center gap-1 mb-2">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <p class="text-neutral-mid text-sm">Rated 5 stars by patients in Huntington Beach and beyond</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            quote: 'Dr. Cheong transformed my smile completely. I can\'t thank him enough for the exceptional care I received! Highly recommend!',
            name: 'Lindsey U.',
            location: 'Huntington Beach',
          },
          {
            quote: 'Dr. Cheong\'s office and team are incredible... I drive from Newport Beach to see them. Excellent experience.',
            name: 'Spencer L.',
            location: 'Newport Beach',
          },
          {
            quote: 'By far the best dental experience I\'ve ever had. Amazing service and quality care. Dr. Cheong is simply the best dentist in So-Cal. Efficient, honest, skilled and super chill.',
            name: 'Michelle L.',
            location: 'Southern California',
          },
        ].map((t) => (
          <div class="bg-brand-light rounded-xl p-6 flex flex-col">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-neutral-mid leading-relaxed text-sm flex-1 mb-4 italic">"{t.quote}"</p>
            <div>
              <div class="font-semibold text-brand-navy text-sm">{t.name}</div>
              <div class="text-xs text-neutral-mid">{t.location}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Common Questions About Prosthodontic Care" />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-8 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
