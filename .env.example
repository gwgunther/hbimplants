# Google APIs (service account JSON path)
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# Google Search Console
GSC_SITE_URL=https://hbimplants.com/

# Google Business Profile
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Google Analytics
GA4_PROPERTY_ID=

# GA4 Measurement (for client-side script)
PUBLIC_GA4_MEASUREMENT_ID=

# Referrals form (Formspree)
